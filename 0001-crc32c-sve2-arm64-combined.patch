index 000000000..7285fc9d2
--- /dev/null
+++ b/util/crc32_iscsi_sve2.S
@@ -0,0 +1,290 @@
+	.arch armv8.5-a+crypto+crc+sve2-aes
+	.file	"crc32_iscsi_sve2.c"
+	.text
+	.align	2
+	.p2align 4,,11
+	.global	crc32_iscsi_sve2
+	.type	crc32_iscsi_sve2, %function
+crc32_iscsi_sve2:
+.LFB4364:
+	.cfi_startproc
+	cntb	x11, all, mul #8
+	cmp	w1, w11
+	blt	.L9
+	cntb	x10
+	cntb	x9, all, mul #2
+	mov	x4, x0

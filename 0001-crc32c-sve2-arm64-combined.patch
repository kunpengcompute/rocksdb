diff --git a/util/crc32c_arm64.cc b/util/crc32c_arm64.cc
new file mode 100644
index 000000000..5763ae1f0
--- /dev/null
+++ b/util/crc32c_arm64.cc
@@ -0,0 +1,157 @@
+#include "util/crc32c_arm64.h"
+
+#if defined(HAVE_ARM64_CRC)
+
+#if defined(__linux__)
+#include <asm/hwcap.h>
+#include <sys/auxv.h>
+#endif
+#if defined(__APPLE__)
+#include <sys/sysctl.h>
+#endif
+
+#if !defined(HWCAP_CRC32)
+#define HWCAP_CRC32 (1ULL << 7)
+#endif
+#if !defined(HWCAP_PMULL)
+#define HWCAP_PMULL (1ULL << 4)
+#endif
+
+constexpr size_t kParallelBlockLength = 42; // 单路并行块长度（8字节*42）
+constexpr size_t k1024ByteThreshold = 1024;    // 大尺寸数据阈值
+constexpr uint32_t kPMULLMergeK0 = 0xe417f38a;  // PMULL合并参数k0
+constexpr uint32_t kPMULLMergeK1 = 0x8f158014;  // PMULL合并参数k1
+
+#ifdef HAVE_ARM64_CRYPTO
+#define CRC32C24BYTES(ITR)                                                  \
+    crc1 = crc32c_u64(crc1, *(buf64 + kParallelBlockLength + (ITR)));       \
+    crc2 = crc32c_u64(crc2, *(buf64 + kParallelBlockLength * 2 + (ITR)));   \
+    crc0 = crc32c_u64(crc0, *(buf64 + (ITR)));
+
+#define CRC32C7X24BYTES(ITR)    \
+    CRC32C24BYTES((ITR)*7 + 0)  \
+    CRC32C24BYTES((ITR)*7 + 1)  \
+    CRC32C24BYTES((ITR)*7 + 2)  \
+    CRC32C24BYTES((ITR)*7 + 3)  \
+    CRC32C24BYTES((ITR)*7 + 4)  \
+    CRC32C24BYTES((ITR)*7 + 5)  \
+    CRC32C24BYTES((ITR)*7 + 6)
+#endif
+
+extern bool pmull_runtime_flag;
+
+uint32_t crc32c_check(void) {
+#if defined(__FreeBSD__)
+    uint64_t auxv = 0;
+    elf_aux_info(AT_HWCAP, &auxv, sizeof(auxv));
+    return (auxv & HWCAP_CRC32) != 0;
+#elif defined(__linux__)
+    const uint64_t auxv = getauxval(AT_HWCAP);
+    return (auxv & HWCAP_CRC32) != 0;
+#elif defined(__APPLE__)
+    int crc_supported = 0;
+    const size_t len = sizeof(crc_supported);
+    if (sysctlbyname("hw.optional.armv8_crc32", &crc_supported, &len, nullptr, 0) == -1) {
+        return 0;
+    }
+    return crc_supported == 1;
+#else
+    return 0;
+#endif
+}
+
+bool crc32c_pmull_check(void) {
+#if defined(__FreeBSD__)
+    uint64_t auxv = 0;
+    elf_aux_info(AT_HWCAP, &auxv, sizeof(auxv));
+    return (auxv & HWCAP_PMULL) != 0;
+#elif defined(__linux__)
+    const uint64_t auxv = getauxval(AT_HWCAP);
+    return (auxv & HWCAP_PMULL) != 0;
+#elif defined(__APPLE__)
+    return true;
+#else
+    return false;
+#endif
+}
+
+#ifdef ROCKSDB_UBSAN_RUN
+#if defined(__clang__)
+__attribute__((__no_sanitize__("alignment")))
+#elif defined(__GNUC__)
+__attribute__((__no_sanitize_undefined__))
+#endif
+#endif
+uint32_t crc32c_arm64(uint32_t crc, unsigned char const *data, size_t len) {
+    crc ^= 0xffffffffU;
+
+    // 空数据快速返回
+    if (len == 0) {
+        return crc ^ 0xffffffffU;
+    }
+
+    const uint8_t* ptr;
+    const uint64_t* buf64 = (uint64_t *)data;
+    size_t remaining = len;
+
+    if (pmull_runtime_flag) {
+#ifdef HAVE_ARM64_CRYPTO
+        while (remaining >= k1024ByteThreshold) {
+            uint32_t crc0 = 0, crc1 = 0, crc2 = 0;
+            uint64_t t0, t1;
+
+            PREF1KL1((uint8_t *)buf64, k1024ByteThreshold);
+
+            // 首8字节初始化
+            crc0 = crc32c_u64(crc, *buf64++);
+
+            CRC32C7X24BYTES(0);
+            CRC32C7X24BYTES(1);
+            CRC32C7X24BYTES(2);
+            CRC32C7X24BYTES(3);
+            CRC32C7X24BYTES(4);
+            CRC32C7X24BYTES(5);
+            buf64 += 3 * kParallelBlockLength;
+
+            // 尾8字节计算
+            crc = crc32c_u64(crc2, *buf64++);
+
+            // PMULL合并3路CRC结果
+            t0 = static_cast<uint64_t>(vmull_p64(crc0, kPMULLMergeK0));
+            t1 = static_cast<uint64_t>(vmull_p64(crc1, kPMULLMergeK1));
+            crc ^= crc32c_u64(0, t1);
+            crc ^= crc32c_u64(0, t0);
+
+            // 更新剩余字节数
+            remaining -= k1024ByteThreshold;
+        }
+
+        if (remaining == 0) return crc ^ (0xffffffffU);
+#endif
+    }
+
+    ptr = (const uint8_t *)buf64;
+    while (remaining >= 8) {
+        crc = crc32c_u64(crc, *(const uint64_t *)ptr);
+        ptr += 8;
+        remaining -= 8;
+    }
+
+    if (remaining >= 4) {
+        crc = crc32c_u32(crc, *(const uint32_t *)ptr);
+        ptr += 4;
+        remaining -= 4;
+    }
+
+    if (remaining >= 2) {
+        crc = crc32c_u16(crc, *(const uint16_t *)ptr);
+        ptr += 2;
+        remaining -= 2;
+    }
+
+    if (remaining) crc = crc32c_u8(crc, *ptr);
+    crc ^= 0xffffffff;
+    return crc;
+}
+
+#endif
